graph TD
    %% Definición de Estilos
    classDef capa1 fill:#f9f9f9,stroke:#f05032,stroke-width:2px,color:#333
    classDef capa2 fill:#f0f7ff,stroke:#0056b3,stroke-width:2px,color:#333
    classDef capa3 fill:#fffdf0,stroke:#d4a017,stroke-width:2px,color:#333
    classDef capa4 fill:#f0fff4,stroke:#2e7d32,stroke-width:2px,color:#333

    %% FLUJO
    subgraph C1 [1.CAPA DE INGESTA]
        A[GitHub Repo] --> B[GitLoader]
        B --> C[CharacterTextSplitter]
    end

    subgraph C2 [2. CAPA DE MEMORIA ]
        C --> D[Google Embeddings]
        D --> E[(Chroma Vector DB)]
    end

    subgraph C3 [3. CAPA DE RECUPERACIÓN]
        F[Pregunta Usuario] --> G[MultiQuery: 3 Variantes]
        G --> H[Ensemble Retriever: MMR + Similitud]
        H -->|Consulta| E
    end

    subgraph C4 [4. CAPA DE GENERACIÓN]
        E -->|Fragmentos| I[Prompt Enriquecido]
        F --> I
        I --> J[Gemini 2.5 Flash]
        J --> K[Streamlit UI: Chat + Código]
    end

    %% Asignación de clases
    class C1 capa1;
    class C2 capa2;
    class C3 capa3;
    class C4 capa4;
